{
  "name": "realstate-website",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "css:build": "vite build && mv src/dist/assets/*.css src/output.css && rm -rf src/dist",
    "prepare": "node -e \"if(require('fs').existsSync('.git/hooks')){require('fs').chmodSync('.git/hooks/pre-commit', '755')}\""
  },
  "devDependencies": {
    "@tailwindcss/vite": "*",
    "@vitejs/plugin-react-swc": "*",
    "react": "*",
    "react-dom": "*",
    "tailwindcss": "*",
    "vite": "*"
  }
}